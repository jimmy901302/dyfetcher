{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
      "builder": "RAILPACK",
      "packages": ["libv8-dev", "libstdc++6", "g++", "python3-dev"]
    },
    
    "deploy": {
      "runtime": "V2",
      "numReplicas": 1,
      "startCommand": "gunicorn -w 1 -k gthread --threads 8 -t 0 -b 0.0.0.0:$PORT main:app",
      "sleepApplication": false,
      "useLegacyStacker": false,
      "ipv6EgressEnabled": false,
      "multiRegionConfig": {
        "us-west2": {
          "numReplicas": 1
        }
      },
      "restartPolicyType": "ON_FAILURE",
      "restartPolicyMaxRetries": 10
    }
  }